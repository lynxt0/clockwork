{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clockwork",
  "version": "0.1.0",
  "identifier": "com.caleb.clockwork",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clockwork",
        "width": 400,
        "height": 620,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "center": true,
        "fullscreen": false,
        "backgroundColor": "#0b0b0d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
